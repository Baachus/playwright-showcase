{
  "name": "playwright-showcase",
  "version": "1.0.0",
  "type": "module",
  "description": "A production-grade Playwright + TypeScript testing showcase covering UI, API, Accessibility, Performance, Security, Visual Regression, Network Mocking, Component Testing, and Multi-Context testing.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:a11y": "playwright test tests/accessibility",
    "test:perf": "playwright test tests/performance",
    "test:security": "playwright test tests/security",
    "test:crawler": "playwright test tests/crawler --project=Crawler",
    "test:visual": "playwright test tests/visual --project=Visual",
    "test:visual:update": "playwright test tests/visual --project=Visual --update-snapshots",
    "visual:baselines:linux": "bash scripts/update-visual-baselines.sh",
    "visual:baselines:linux:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-visual-baselines.ps1",
    "test:mock": "playwright test tests/mocking --project=Mocking",
    "test:components": "playwright test tests/components --project=Components",
    "test:multi-context": "playwright test tests/multi-context --project=Multi-Context",
    "test:multi-tab": "playwright test tests/multi-context --project=Multi-Context --grep @multi-tab",
    "test:multi-window": "playwright test tests/multi-context --project=Multi-Context --grep @multi-window",
    "test:multi-user": "playwright test tests/multi-context --project=Multi-Context --grep @multi-user",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "lighthouse:open": "open reports/lighthouse/index.html || xdg-open reports/lighthouse/index.html",
    "allure:generate": "node scripts/allure-generate.mjs",
    "allure:generate:single": "allure generate ./allure-results --single-file -o ./allure-report-single --clean",
    "allure:open": "npx allure open allure-report",
    "allure:serve": "npx allure serve allure-results",
    "allure:trend": "npm test && node scripts/allure-generate.mjs && npx allure open allure-report",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:contract": "playwright test tests/api/api-contract.spec.ts --project=API",
    "test:websocket": "playwright test tests/websocket --project=WebSocket-Mock --project=WebSocket-Realtime",
    "test:ws-mock": "playwright test tests/websocket --project=WebSocket-Mock",
    "test:ws-realtime": "playwright test tests/websocket --project=WebSocket-Realtime",
    "test:ws-mock:smoke": "playwright test tests/websocket --project=WebSocket-Mock --grep @smoke",
    "test:email": "playwright test tests/email --project=Email",
    "test:email:smoke": "playwright test tests/email --project=Email --grep @smoke",
    "email:server": "tsx tools/email-sender/server.ts",
    "mailpit": "node tools/mailpit/run.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^7.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "allure-commandline": "^2.40.0",
    "allure-js-commons": "^3.8.0",
    "allure-playwright": "^3.8.0",
    "axe-core": "^4.11.4",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.2",
    "express": "^5.0.0",
    "lighthouse": "^12.6.1",
    "nodemailer": "^9.0.3",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "ws": "^8.18.1",
    "zod": "^3.25.76"
  }
}
